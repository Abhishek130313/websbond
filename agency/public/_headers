/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN

# index.html: always revalidate so deploys take effect immediately
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Hashed JS/CSS chunks: 1 year immutable (Vite content-hashes guarantee freshness)
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable

/assets/*.css
  Cache-Control: public, max-age=31536000, immutable

# Fonts: self-hosted via fontsource, long-lived cache + CORS
/assets/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

/assets/*.woff
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Images in /assets/
/assets/*.webp
  Cache-Control: public, max-age=31536000, immutable

/assets/*.png
  Cache-Control: public, max-age=31536000, immutable

/assets/*.jpg
  Cache-Control: public, max-age=31536000, immutable

/assets/*.svg
  Cache-Control: public, max-age=31536000, immutable

# Favicon / public images
/favicon.ico
  Cache-Control: public, max-age=604800

/og-image.jpg
  Cache-Control: public, max-age=86400

# Logos
/logos/*.svg
  Cache-Control: public, max-age=31536000, immutable
