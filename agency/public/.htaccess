<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve existing files directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA: serve index.html for all other routes
  RewriteRule ^ index.html [L]
</IfModule>

# Security: block sensitive files
<FilesMatch "\.(env|git|lock|md)$">
  Deny from all
</FilesMatch>

# Security: hide PHP version
Header always unset X-Powered-By

# === Aggressive Caching ===
# Hashed/fingerprinted static assets → 1 year immutable
<FilesMatch "\.(jpg|jpeg|png|webp|avif|svg|ico|woff|woff2|ttf|eot|otf)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# JS/CSS with content hashes (Vite output) → 1 year immutable
<FilesMatch "\.[a-f0-9]{8}\.(js|css)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# index.html → no cache (always fresh for SPA routing)
<FilesMatch "^index\.html$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>

# === Compression ===
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json application/xml text/plain image/svg+xml font/woff font/woff2
  # Set compression level
  DeflateCompressionLevel 6
</IfModule>

# Brotli compression (if available on server)
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/css application/javascript application/json image/svg+xml font/woff font/woff2
</IfModule>

# === Performance Headers ===
<IfModule mod_headers.c>
  # Prevent MIME type sniffing
  Header always set X-Content-Type-Options "nosniff"
  # Remove X-Frame-Options (use CSP instead for modern browsers)
  # Referrer policy
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  # Enable Keep-Alive
  Header set Connection "Keep-Alive"
</IfModule>

# === Font CORS (needed for CDN) ===
<FilesMatch "\.(woff|woff2|ttf|eot|otf)$">
  Header set Access-Control-Allow-Origin "*"
</FilesMatch>
